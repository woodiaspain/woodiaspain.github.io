{
  "name": "Woodia Spain - Contacto Web",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "woodia-contact",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "node-webhook",
      "name": "Recibir contacto web",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [0, 0],
      "webhookId": "woodia-contact-post"
    },
    {
      "parameters": {
        "sendTo": "info@woodiaspain.com",
        "subject": "=🏪 Nuevo contacto - {{ $json.body.nombre }} ({{ $json.body.negocio }})",
        "emailType": "html",
        "message": "=<h2 style=\"color:#c8a951\">Nuevo contacto desde woodiaspain.com</h2>\n<table style=\"border-collapse:collapse;width:100%\">\n  <tr><td style=\"padding:8px;border:1px solid #ddd;font-weight:bold\">Nombre</td><td style=\"padding:8px;border:1px solid #ddd\">{{ $json.body.nombre }}</td></tr>\n  <tr><td style=\"padding:8px;border:1px solid #ddd;font-weight:bold\">Negocio</td><td style=\"padding:8px;border:1px solid #ddd\">{{ $json.body.negocio }}</td></tr>\n  <tr><td style=\"padding:8px;border:1px solid #ddd;font-weight:bold\">Teléfono</td><td style=\"padding:8px;border:1px solid #ddd\">{{ $json.body.telefono }}</td></tr>\n  <tr><td style=\"padding:8px;border:1px solid #ddd;font-weight:bold\">Email</td><td style=\"padding:8px;border:1px solid #ddd\">{{ $json.body.email }}</td></tr>\n  <tr><td style=\"padding:8px;border:1px solid #ddd;font-weight:bold\">Mensaje</td><td style=\"padding:8px;border:1px solid #ddd\">{{ $json.body.mensaje }}</td></tr>\n  <tr><td style=\"padding:8px;border:1px solid #ddd;font-weight:bold\">Fecha</td><td style=\"padding:8px;border:1px solid #ddd\">{{ $json.body.fecha }}</td></tr>\n</table>\n<br>\n<a href=\"https://wa.me/34{{ $json.body.telefono }}\" style=\"background:#25D366;color:white;padding:10px 20px;text-decoration:none;border-radius:6px\">Responder por WhatsApp</a>",
        "options": {}
      },
      "id": "node-gmail",
      "name": "Enviar email contacto",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2.1,
      "position": [300, 0],
      "credentials": {
        "gmailOAuth2": {
          "id": "",
          "name": "Gmail Pablo"
        }
      }
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={\"success\": true}",
        "options": {
